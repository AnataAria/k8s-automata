#!/bin/bash

# Kubernetes backup script
# Generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

# Configuration
BACKUP_DIR="{{ backup.dir | default('/var/backups/kubernetes') }}"
RETENTION_DAYS="{{ backup.retention_days | default(7) }}"
ETCD_ENDPOINTS="{% for host in groups['etcds'] %}https://{{ hostvars[host]['ansible_host'] }}:2379{% if not loop.last %},{% endif %}{% endfor %}"
ETCD_CACERT="/etc/kubernetes/pki/etcd/ca.crt"
ETCD_CERT="/etc/kubernetes/pki/apiserver-etcd-client.crt"
ETCD_KEY="/etc/kubernetes/pki/apiserver-etcd-client.key"
DATE=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/k8s_backup_${DATE}.tar.gz"
TEMP_DIR="/tmp/k8s_backup_${DATE}"

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Error handling
cleanup() {
    if [ -d "${TEMP_DIR}" ]; then
        rm -rf "${TEMP_DIR}"
    fi
}
trap cleanup EXIT

# Create backup directory
mkdir -p "${BACKUP_DIR}"
mkdir -p "${TEMP_DIR}"

# Start backup process
log "Starting Kubernetes backup..."

# 1. Backup etcd data
log "Backing up etcd data..."
if command -v etcdctl > /dev/null; then
    etcdctl --endpoints="${ETCD_ENDPOINTS}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        snapshot save "${TEMP_DIR}/etcd_snapshot.db"

    # Verify etcd snapshot
    if etcdctl snapshot status "${TEMP_DIR}/etcd_snapshot.db" > /dev/null; then
        log "etcd snapshot created and verified"
    else
        log "ERROR: etcd snapshot verification failed"
        exit 1
    fi
else
    log "WARNING: etcdctl not found, skipping etcd backup"
fi

# 2. Backup Kubernetes certificates and keys
log "Backing up Kubernetes PKI..."
if [ -d "/etc/kubernetes/pki" ]; then
    cp -r /etc/kubernetes/pki "${TEMP_DIR}/"
    log "Kubernetes PKI backed up"
else
    log "WARNING: /etc/kubernetes/pki not found"
fi

# 3. Backup kubeadm configuration
log "Backing up kubeadm configuration..."
if [ -f "/etc/kubernetes/admin.conf" ]; then
    cp /etc/kubernetes/admin.conf "${TEMP_DIR}/"
fi
if [ -f "/etc/kubernetes/controller-manager.conf" ]; then
    cp /etc/kubernetes/controller-manager.conf "${TEMP_DIR}/"
fi
if [ -f "/etc/kubernetes/scheduler.conf" ]; then
    cp /etc/kubernetes/scheduler.conf "${TEMP_DIR}/"
fi
if [ -f "/etc/kubernetes/kubelet.conf" ]; then
    cp /etc/kubernetes/kubelet.conf "${TEMP_DIR}/"
fi

# 4. Backup Kubernetes manifests
log "Backing up Kubernetes manifests..."
if [ -d "/etc/kubernetes/manifests" ]; then
    cp -r /etc/kubernetes/manifests "${TEMP_DIR}/"
    log "Static pod manifests backed up"
fi

# 5. Backup kubelet configuration
log "Backing up kubelet configuration..."
if [ -f "/var/lib/kubelet/config.yaml" ]; then
    mkdir -p "${TEMP_DIR}/kubelet"
    cp /var/lib/kubelet/config.yaml "${TEMP_DIR}/kubelet/"
fi

# 6. Backup cluster resources (if kubectl is available and cluster is accessible)
log "Backing up cluster resources..."
if command -v kubectl > /dev/null && kubectl cluster-info > /dev/null 2>&1; then
    mkdir -p "${TEMP_DIR}/cluster-resources"

    # Backup all namespaces
    kubectl get namespaces -o yaml > "${TEMP_DIR}/cluster-resources/namespaces.yaml" 2>/dev/null || true

    # Backup cluster-level resources
    kubectl get nodes -o yaml > "${TEMP_DIR}/cluster-resources/nodes.yaml" 2>/dev/null || true
    kubectl get clusterroles -o yaml > "${TEMP_DIR}/cluster-resources/clusterroles.yaml" 2>/dev/null || true
    kubectl get clusterrolebindings -o yaml > "${TEMP_DIR}/cluster-resources/clusterrolebindings.yaml" 2>/dev/null || true
    kubectl get persistentvolumes -o yaml > "${TEMP_DIR}/cluster-resources/persistentvolumes.yaml" 2>/dev/null || true
    kubectl get storageclasses -o yaml > "${TEMP_DIR}/cluster-resources/storageclasses.yaml" 2>/dev/null || true

    # Backup resources from all namespaces
    for ns in $(kubectl get namespaces -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo ""); do
        if [ -n "$ns" ]; then
            mkdir -p "${TEMP_DIR}/cluster-resources/namespaces/${ns}"
            kubectl get all,secrets,configmaps,persistentvolumeclaims,ingresses,networkpolicies \
                -n "$ns" -o yaml > "${TEMP_DIR}/cluster-resources/namespaces/${ns}/resources.yaml" 2>/dev/null || true
        fi
    done

    log "Cluster resources backed up"
else
    log "WARNING: kubectl not available or cluster not accessible, skipping cluster resources backup"
fi

# 7. Create compressed archive
log "Creating compressed backup archive..."
cd "$(dirname "${TEMP_DIR}")"
tar -czf "${BACKUP_FILE}" "$(basename "${TEMP_DIR}")"

# Verify backup file was created
if [ -f "${BACKUP_FILE}" ]; then
    BACKUP_SIZE=$(du -h "${BACKUP_FILE}" | cut -f1)
    log "Backup created successfully: ${BACKUP_FILE} (${BACKUP_SIZE})"
else
    log "ERROR: Failed to create backup file"
    exit 1
fi

# 8. Set proper permissions
chmod 600 "${BACKUP_FILE}"

# 9. Cleanup old backups
log "Cleaning up old backups (keeping last ${RETENTION_DAYS} days)..."
find "${BACKUP_DIR}" -name "k8s_backup_*.tar.gz" -type f -mtime +${RETENTION_DAYS} -delete

# 10. Generate backup manifest
log "Generating backup manifest..."
cat > "${BACKUP_DIR}/k8s_backup_${DATE}.manifest" << EOF
# Kubernetes Backup Manifest
# Generated: $(date)
# Backup File: ${BACKUP_FILE}
# Backup Size: ${BACKUP_SIZE}
# Hostname: $(hostname)
# Kubernetes Version: $(kubectl version --client --short 2>/dev/null | grep Client || echo "Unknown")

## Backup Contents:
$(tar -tzf "${BACKUP_FILE}" | head -20)
$([ $(tar -tzf "${BACKUP_FILE}" | wc -l) -gt 20 ] && echo "... and $(( $(tar -tzf "${BACKUP_FILE}" | wc -l) - 20 )) more files")

## etcd Snapshot Info:
$([ -f "${TEMP_DIR}/etcd_snapshot.db" ] && etcdctl snapshot status "${TEMP_DIR}/etcd_snapshot.db" 2>/dev/null || echo "etcd snapshot not available")
EOF

log "Kubernetes backup completed successfully"
log "Backup file: ${BACKUP_FILE}"
log "Manifest file: ${BACKUP_DIR}/k8s_backup_${DATE}.manifest"

exit 0

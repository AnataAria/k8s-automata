# Kubernetes log rotation configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# Kubernetes audit logs
/var/log/kubernetes/audit.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 0640 root root
    copytruncate
    postrotate
        # Send USR1 signal to kube-apiserver to reopen log files
        /bin/kill -USR1 $(pgrep kube-apiserver) 2>/dev/null || true
    endscript
}

# Kubernetes component logs (if file-based logging is used)
/var/log/kubernetes/*.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 0640 root root
    copytruncate
}


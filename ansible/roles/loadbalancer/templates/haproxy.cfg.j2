global
    daemon
    user haproxy
    group haproxy
    maxconn {{ loadbalancer_haproxy_global.maxconn }}
    log stdout local0 {{ loadbalancer_haproxy_global.log_level }}

defaults
    mode tcp
    option dontlognull
    timeout connect {{ loadbalancer_haproxy_timeouts.connect }}
    timeout client {{ loadbalancer_haproxy_timeouts.client }}
    timeout server {{ loadbalancer_haproxy_timeouts.server }}
    timeout check {{ loadbalancer_haproxy_timeouts.check }}
    retries 3

frontend kubernetes_api
    bind *:{{ loadbalancer_haproxy_ports.api_port }}
    option tcplog
    default_backend kubernetes_control_planes

backend kubernetes_control_planes
    balance {{ loadbalancer_balance_algorithm }}
    option tcp-check
{% for host in groups['control_plane'] %}
    server {{ host }} {{ hostvars[host].ip | default(hostvars[host].access_ip | default(hostvars[host].ansible_host)) }}:{{ loadbalancer_backend_port }} check inter {{ loadbalancer_health_checks.interval }} fall {{ loadbalancer_health_checks.fall }} rise {{ loadbalancer_health_checks.rise }}
{% endfor %}
{% if loadbalancer_stats.enabled | bool %}
listen stats
    bind *:{{ loadbalancer_haproxy_ports.stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats refresh 10s
    stats auth {{ loadbalancer_stats.user }}:{{ loadbalancer_stats.password }}
{% endif %}

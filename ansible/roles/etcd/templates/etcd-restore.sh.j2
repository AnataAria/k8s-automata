#!/bin/bash

# etcd restore script
# Generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

# Configuration
ETCD_ENDPOINTS="{% for host in groups['etcds'] %}https://{{ hostvars[host]['ansible_host'] }}:{{ etcd_client_port }}{% if not loop.last %},{% endif %}{% endfor %}"
ETCD_CACERT="{{ etcd_cert_dir }}/ca.crt"
ETCD_CERT="{{ etcd_cert_dir }}/healthcheck-client.crt"
ETCD_KEY="{{ etcd_cert_dir }}/healthcheck-client.key"
BACKUP_DIR="{{ etcd_backup_dir }}"
DATA_DIR="{{ etcd_data_dir }}"
RESTORE_DIR="{{ etcd_data_dir }}_restore_$(date +%Y%m%d_%H%M%S)"

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Usage function
usage() {
    echo "Usage: $0 <backup_file>"
    echo "  backup_file: Path to the etcd backup file (.db or .db.gz)"
    echo ""
    echo "Examples:"
    echo "  $0 ${BACKUP_DIR}/etcd_backup_20241108_120000.db"
    echo "  $0 ${BACKUP_DIR}/etcd_backup_20241108_120000.db.gz"
    exit 1
}

# Check arguments
if [ $# -ne 1 ]; then
    log "ERROR: Missing backup file argument"
    usage
fi

BACKUP_FILE="$1"

# Validate backup file exists
if [ ! -f "${BACKUP_FILE}" ]; then
    log "ERROR: Backup file not found: ${BACKUP_FILE}"
    exit 1
fi

# Check if backup file is compressed
if [[ "${BACKUP_FILE}" == *.gz ]]; then
    log "Decompressing backup file..."
    DECOMPRESSED_FILE="${BACKUP_FILE%.gz}"
    if gunzip -c "${BACKUP_FILE}" > "${DECOMPRESSED_FILE}"; then
        BACKUP_FILE="${DECOMPRESSED_FILE}"
        log "Backup decompressed to: ${BACKUP_FILE}"
        CLEANUP_DECOMPRESSED=true
    else
        log "ERROR: Failed to decompress backup file"
        exit 1
    fi
else
    CLEANUP_DECOMPRESSED=false
fi

# Verify backup integrity
log "Verifying backup integrity..."
if ! /usr/local/bin/etcdctl snapshot status "${BACKUP_FILE}" > /dev/null; then
    log "ERROR: Backup verification failed"
    exit 1
fi

log "Backup verification passed"

# Warning and confirmation
echo ""
echo "WARNING: This will restore etcd from backup and may cause data loss!"
echo "Current data directory will be moved to: ${RESTORE_DIR}"
echo "Backup file: ${BACKUP_FILE}"
echo ""
read -p "Are you sure you want to continue? (yes/no): " -r
if [[ ! $REPLY =~ ^[Yy][Ee][Ss]$ ]]; then
    log "Restore cancelled by user"
    exit 0
fi

# Stop etcd service
log "Stopping etcd service..."
if systemctl is-active --quiet etcd; then
    systemctl stop etcd
    log "etcd service stopped"
else
    log "etcd service was not running"
fi

# Backup current data directory
if [ -d "${DATA_DIR}" ]; then
    log "Moving current data directory to: ${RESTORE_DIR}"
    mv "${DATA_DIR}" "${RESTORE_DIR}"
else
    log "No existing data directory found"
fi

# Restore from backup
log "Restoring etcd from backup..."
if /usr/local/bin/etcdctl snapshot restore "${BACKUP_FILE}" \
    --data-dir="${DATA_DIR}" \
    --name="{{ inventory_hostname }}" \
    --initial-cluster="{% for host in groups['etcds'] %}{{ host }}=https://{{ hostvars[host]['ansible_host'] }}:{{ etcd_peer_port }}{% if not loop.last %},{% endif %}{% endfor %}" \
    --initial-cluster-token="{{ etcd_initial_cluster_token }}" \
    --initial-advertise-peer-urls="https://{{ ansible_default_ipv4.address }}:{{ etcd_peer_port }}"; then

    log "Restore completed successfully"

    # Set proper ownership
    chown -R {{ etcd_user }}:{{ etcd_group }} "${DATA_DIR}"

    # Start etcd service
    log "Starting etcd service..."
    systemctl start etcd

    # Wait for etcd to be ready
    log "Waiting for etcd to be ready..."
    for i in {1..30}; do
        if /usr/local/bin/etcdctl \
            --endpoints="https://127.0.0.1:{{ etcd_client_port }}" \
            --cacert="${ETCD_CACERT}" \
            --cert="${ETCD_CERT}" \
            --key="${ETCD_KEY}" \
            endpoint health > /dev/null 2>&1; then
            log "etcd is healthy"
            break
        fi

        if [ $i -eq 30 ]; then
            log "ERROR: etcd failed to become healthy after restore"
            exit 1
        fi

        sleep 2
    done

    log "etcd restore process completed successfully"

else
    log "ERROR: Failed to restore from backup"

    # Restore original data directory if restore failed
    if [ -d "${RESTORE_DIR}" ]; then
        log "Restoring original data directory..."
        mv "${RESTORE_DIR}" "${DATA_DIR}"
        chown -R {{ etcd_user }}:{{ etcd_group }} "${DATA_DIR}"
    fi

    exit 1
fi

# Cleanup decompressed file if we created it
if [ "${CLEANUP_DECOMPRESSED}" = true ]; then
    rm -f "${BACKUP_FILE}"
fi

log "Restore completed. Original data backed up to: ${RESTORE_DIR}"

#!/bin/bash

# etcd backup script
# Generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

# Configuration
ETCD_ENDPOINTS="{% for host in groups['etcds'] %}https://{{ hostvars[host]['ansible_host'] }}:{{ etcd_client_port }}{% if not loop.last %},{% endif %}{% endfor %}"
ETCD_CACERT="{{ etcd_cert_dir }}/ca.crt"
ETCD_CERT="{{ etcd_cert_dir }}/healthcheck-client.crt"
ETCD_KEY="{{ etcd_cert_dir }}/healthcheck-client.key"
BACKUP_DIR="{{ etcd_backup_dir }}"
RETENTION_DAYS="{{ etcd_backup.retention_days }}"
DATE=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/etcd_backup_${DATE}.db"

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Create backup directory if it doesn't exist
mkdir -p "${BACKUP_DIR}"

# Perform backup
log "Starting etcd backup..."

if /usr/local/bin/etcdctl \
    --endpoints="${ETCD_ENDPOINTS}" \
    --cacert="${ETCD_CACERT}" \
    --cert="${ETCD_CERT}" \
    --key="${ETCD_KEY}" \
    snapshot save "${BACKUP_FILE}"; then

    log "Backup completed successfully: ${BACKUP_FILE}"

    # Verify backup
    if /usr/local/bin/etcdctl snapshot status "${BACKUP_FILE}" > /dev/null; then
        log "Backup verification passed"

        {% if etcd_backup.compression | bool %}
        # Compress backup
        if gzip "${BACKUP_FILE}"; then
            log "Backup compressed: ${BACKUP_FILE}.gz"
            BACKUP_FILE="${BACKUP_FILE}.gz"
        else
            log "Warning: Failed to compress backup"
        fi
        {% endif %}

        # Set proper permissions
        chmod 600 "${BACKUP_FILE}"

        # Cleanup old backups
        log "Cleaning up backups older than ${RETENTION_DAYS} days..."
        find "${BACKUP_DIR}" -name "etcd_backup_*.db*" -type f -mtime +${RETENTION_DAYS} -delete

        log "Backup process completed successfully"
        exit 0
    else
        log "ERROR: Backup verification failed"
        rm -f "${BACKUP_FILE}"
        exit 1
    fi
else
    log "ERROR: Failed to create backup"
    exit 1
fi

#!/bin/bash

# etcd health check script
# Generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

# Configuration
ETCD_ENDPOINTS="{% for host in groups['etcds'] %}https://{{ hostvars[host]['ansible_host'] }}:{{ etcd_client_port }}{% if not loop.last %},{% endif %}{% endfor %}"
ETCD_CACERT="{{ etcd_cert_dir }}/ca.crt"
ETCD_CERT="{{ etcd_cert_dir }}/healthcheck-client.crt"
ETCD_KEY="{{ etcd_cert_dir }}/healthcheck-client.key"
HEALTH_CHECK_INTERVAL="{{ etcd_monitoring.health_check_interval }}"
MAX_LATENCY_MS="{{ etcd_health_thresholds.max_latency_ms }}"
MAX_FAILED_REQUESTS="{{ etcd_health_thresholds.max_failed_requests }}"

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Health check function
check_health() {
    local endpoint="$1"
    local start_time=$(date +%s%N)

    if /usr/local/bin/etcdctl \
        --endpoints="${endpoint}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        endpoint health > /dev/null 2>&1; then

        local end_time=$(date +%s%N)
        local latency_ms=$(( (end_time - start_time) / 1000000 ))

        if [ ${latency_ms} -gt ${MAX_LATENCY_MS} ]; then
            log "WARNING: High latency on ${endpoint}: ${latency_ms}ms (threshold: ${MAX_LATENCY_MS}ms)"
            return 1
        else
            log "OK: ${endpoint} - latency: ${latency_ms}ms"
            return 0
        fi
    else
        log "ERROR: Health check failed for ${endpoint}"
        return 1
    fi
}

# Check cluster status
check_cluster_status() {
    log "Checking cluster status..."

    if /usr/local/bin/etcdctl \
        --endpoints="${ETCD_ENDPOINTS}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        endpoint status --cluster -w table; then

        log "Cluster status check passed"
        return 0
    else
        log "ERROR: Cluster status check failed"
        return 1
    fi
}

# Check member list
check_member_list() {
    log "Checking member list..."

    if /usr/local/bin/etcdctl \
        --endpoints="${ETCD_ENDPOINTS}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        member list; then

        log "Member list check passed"
        return 0
    else
        log "ERROR: Member list check failed"
        return 1
    fi
}

# Check disk space
check_disk_space() {
    local data_dir="{{ etcd_data_dir }}"
    local usage=$(df "${data_dir}" | awk 'NR==2 {print $(NF-1)}' | sed 's/%//')
    local threshold="{{ etcd_health_thresholds.max_disk_usage_percent }}"

    if [ ${usage} -gt ${threshold} ]; then
        log "WARNING: High disk usage in ${data_dir}: ${usage}% (threshold: ${threshold}%)"
        return 1
    else
        log "OK: Disk usage in ${data_dir}: ${usage}%"
        return 0
    fi
}

# Check memory usage
check_memory_usage() {
    local threshold="{{ etcd_health_thresholds.max_memory_usage_percent }}"
    local usage=$(ps -o pid,ppid,cmd,%mem,%cpu --sort=-%mem | grep '[e]tcd' | awk '{sum+=$4} END {print int(sum)}')

    if [ -n "${usage}" ] && [ ${usage} -gt ${threshold} ]; then
        log "WARNING: High memory usage by etcd: ${usage}% (threshold: ${threshold}%)"
        return 1
    else
        log "OK: Memory usage by etcd: ${usage:-0}%"
        return 0
    fi
}

# Main health check function
run_health_checks() {
    local failed_checks=0
    local total_checks=0

    log "Starting etcd health checks..."

    # Check individual endpoints
{% for host in groups['etcds'] %}
    ((total_checks++))
    if ! check_health "https://{{ hostvars[host]['ansible_host'] }}:{{ etcd_client_port }}"; then
        ((failed_checks++))
    fi
{% endfor %}

    # Check cluster status
    ((total_checks++))
    if ! check_cluster_status; then
        ((failed_checks++))
    fi

    # Check member list
    ((total_checks++))
    if ! check_member_list; then
        ((failed_checks++))
    fi

    # Check disk space (only on local node)
    if [ "$(hostname)" = "{{ inventory_hostname }}" ]; then
        ((total_checks++))
        if ! check_disk_space; then
            ((failed_checks++))
        fi

        ((total_checks++))
        if ! check_memory_usage; then
            ((failed_checks++))
        fi
    fi

    # Summary
    log "Health check completed: ${failed_checks}/${total_checks} checks failed"

    if [ ${failed_checks} -eq 0 ]; then
        log "All health checks passed"
        return 0
    elif [ ${failed_checks} -gt ${MAX_FAILED_REQUESTS} ]; then
        log "CRITICAL: Too many failed checks (${failed_checks} > ${MAX_FAILED_REQUESTS})"
        return 2
    else
        log "WARNING: Some checks failed"
        return 1
    fi
}

# Usage function
usage() {
    echo "Usage: $0 [OPTIONS]"
    echo "  --once        Run health check once and exit"
    echo "  --continuous  Run health checks continuously (default)"
    echo "  --help        Show this help message"
    exit 1
}

# Parse command line arguments
MODE="continuous"
case "${1:-}" in
    --once)
        MODE="once"
        ;;
    --continuous)
        MODE="continuous"
        ;;
    --help)
        usage
        ;;
    "")
        # Default mode
        ;;
    *)
        log "ERROR: Unknown option: $1"
        usage
        ;;
esac

# Run health checks
if [ "${MODE}" = "once" ]; then
    run_health_checks
    exit $?
else
    log "Starting continuous health monitoring (interval: ${HEALTH_CHECK_INTERVAL})"
    while true; do
        run_health_checks
        log "Sleeping for ${HEALTH_CHECK_INTERVAL}..."
        sleep "${HEALTH_CHECK_INTERVAL}"
    done
fi

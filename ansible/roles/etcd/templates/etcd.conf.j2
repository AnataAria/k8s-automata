# etcd config — generated by Ansible
# Node: {{ inventory_hostname }} | IP: {{ ansible_host }}

# Identity
ETCD_NAME="{{ etcd_name }}"
ETCD_DATA_DIR="{{ etcd_data_dir }}"

# Client traffic
ETCD_LISTEN_CLIENT_URLS="https://{{ ansible_host }}:{{ etcd_client_port }},https://127.0.0.1:{{ etcd_client_port }}"
ETCD_ADVERTISE_CLIENT_URLS="https://{{ ansible_host }}:{{ etcd_client_port }}"

# Peer traffic
ETCD_LISTEN_PEER_URLS="https://{{ ansible_host }}:{{ etcd_peer_port }}"
ETCD_INITIAL_ADVERTISE_PEER_URLS="https://{{ ansible_host }}:{{ etcd_peer_port }}"

# Cluster bootstrap
ETCD_INITIAL_CLUSTER_STATE="{{ etcd_initial_cluster_state }}"
ETCD_INITIAL_CLUSTER_TOKEN="{{ etcd_cluster_token }}"
ETCD_INITIAL_CLUSTER="{% for peer in etcd_peers %}{{ peer.name }}=https://{{ peer.ip }}:{{ etcd_peer_port }}{% if not loop.last %},{% endif %}{% endfor %}"

# TLS — client
ETCD_CERT_FILE="{{ etcd_cert_dir }}/server.crt"
ETCD_KEY_FILE="{{ etcd_cert_dir }}/server.key"
ETCD_TRUSTED_CA_FILE="{{ etcd_cert_dir }}/ca.crt"
ETCD_CLIENT_CERT_AUTH="true"

# TLS — peer
ETCD_PEER_CERT_FILE="{{ etcd_cert_dir }}/peer.crt"
ETCD_PEER_KEY_FILE="{{ etcd_cert_dir }}/peer.key"
ETCD_PEER_TRUSTED_CA_FILE="{{ etcd_cert_dir }}/ca.crt"
ETCD_PEER_CLIENT_CERT_AUTH="true"
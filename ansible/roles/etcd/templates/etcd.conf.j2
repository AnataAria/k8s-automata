name: "{{ etcd_name }}"
data-dir: "{{ etcd_data_dir }}"
listen-peer-urls: "https://{{ etcd_ip }}:{{ etcd_peer_port }}"
listen-client-urls: "https://{{ etcd_ip }}:{{ etcd_client_port }},https://127.0.0.1:{{ etcd_client_port }}"
initial-advertise-peer-urls: "https://{{ etcd_ip }}:{{ etcd_peer_port }}"
advertise-client-urls: "https://{{ etcd_ip }}:{{ etcd_client_port }}"
initial-cluster-state: "{{ etcd_initial_cluster_state }}"
initial-cluster-token: "{{ etcd_cluster_token }}"
initial-cluster: "{% for peer in etcd_peers %}{{ peer.name }}=https://{{ peer.ip }}:{{ etcd_peer_port }}{% if not loop.last %},{% endif %}{% endfor %}"

client-transport-security:
  cert-file: "{{ etcd_cert_dir }}/server.crt"
  key-file: "{{ etcd_cert_dir }}/server.key"
  trusted-ca-file: "{{ etcd_cert_dir }}/ca.crt"
  client-cert-auth: true

peer-transport-security:
  cert-file: "{{ etcd_cert_dir }}/peer.crt"
  key-file: "{{ etcd_cert_dir }}/peer.key"
  trusted-ca-file: "{{ etcd_cert_dir }}/ca.crt"
  client-cert-auth: true

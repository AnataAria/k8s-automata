# etcd logrotate configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

# etcd application logs
{{ etcd_log_dir }}/*.log {
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    create 0640 {{ etcd_user }} {{ etcd_group }}
    postrotate
        # Send USR1 signal to etcd process to reopen log files
        /bin/kill -USR1 `cat /var/run/etcd.pid 2>/dev/null` 2>/dev/null || true
    endscript
}

# etcd backup logs
/var/log/etcd-backup.log {
    weekly
    missingok
    rotate 12
    compress
    delaycompress
    notifempty
    create 0640 root root
    copytruncate
}

# etcd maintenance logs
/var/log/etcd-maintenance.log {
    weekly
    missingok
    rotate 12
    compress
    delaycompress
    notifempty
    create 0640 root root
    copytruncate
}

# etcd health check logs (if file-based logging is used)
/var/log/etcd-health.log {
    weekly
    missingok
    rotate 8
    compress
    delaycompress
    notifempty
    create 0640 root root
    copytruncate
}

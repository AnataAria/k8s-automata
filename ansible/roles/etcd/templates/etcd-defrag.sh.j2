#!/bin/bash

# etcd defragmentation script
# Generated by Ansible - DO NOT EDIT MANUALLY

set -euo pipefail

# Configuration
ETCD_ENDPOINTS="{% for host in groups['etcds'] %}https://{{ hostvars[host]['ansible_host'] }}:{{ etcd_client_port }}{% if not loop.last %},{% endif %}{% endfor %}"
ETCD_CACERT="{{ etcd_cert_dir }}/ca.crt"
ETCD_CERT="{{ etcd_cert_dir }}/healthcheck-client.crt"
ETCD_KEY="{{ etcd_cert_dir }}/healthcheck-client.key"
DEFRAG_TIMEOUT="{{ etcd_maintenance.defrag_timeout }}"
LOCAL_ENDPOINT="https://127.0.0.1:{{ etcd_client_port }}"

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Check if current node is etcd member
check_local_etcd() {
    if ! /usr/local/bin/etcdctl \
        --endpoints="${LOCAL_ENDPOINT}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        --command-timeout=5s \
        endpoint health > /dev/null 2>&1; then
        log "Local etcd endpoint is not healthy, skipping defragmentation"
        exit 0
    fi
}

# Get cluster member list
get_cluster_members() {
    /usr/local/bin/etcdctl \
        --endpoints="${ETCD_ENDPOINTS}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        --write-out=simple \
        member list | awk '{print $5}' | tr ',' '\n' | grep -E '^https://' || true
}

# Defragment single endpoint
defrag_endpoint() {
    local endpoint="$1"
    log "Starting defragmentation for endpoint: ${endpoint}"

    # Check endpoint health first
    if ! /usr/local/bin/etcdctl \
        --endpoints="${endpoint}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        --command-timeout=10s \
        endpoint health > /dev/null 2>&1; then
        log "WARNING: Endpoint ${endpoint} is not healthy, skipping defragmentation"
        return 1
    fi

    # Get DB size before defrag
    local before_size=$(timeout 10s /usr/local/bin/etcdctl \
        --endpoints="${endpoint}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        endpoint status --write-out=simple | awk '{print $5}' | head -1 || echo "unknown")

    # Perform defragmentation
    if timeout "${DEFRAG_TIMEOUT}" /usr/local/bin/etcdctl \
        --endpoints="${endpoint}" \
        --cacert="${ETCD_CACERT}" \
        --cert="${ETCD_CERT}" \
        --key="${ETCD_KEY}" \
        defrag; then

        # Get DB size after defrag
        sleep 2  # Allow some time for the database to settle
        local after_size=$(timeout 10s /usr/local/bin/etcdctl \
            --endpoints="${endpoint}" \
            --cacert="${ETCD_CACERT}" \
            --cert="${ETCD_CERT}" \
            --key="${ETCD_KEY}" \
            endpoint status --write-out=simple | awk '{print $5}' | head -1 || echo "unknown")

        log "SUCCESS: Defragmented ${endpoint} - DB size before: ${before_size} bytes, after: ${after_size} bytes"
        return 0
    else
        log "ERROR: Failed to defragment ${endpoint}"
        return 1
    fi
}

# Main defragmentation function
main() {
    log "Starting etcd defragmentation process"

    # Check if local etcd is running
    check_local_etcd

    # Only run defrag on the current node to avoid concurrent defragmentation
    local current_hostname="{{ inventory_hostname }}"
    local current_ip="{{ ansible_host }}"
    local local_endpoint="https://${current_ip}:{{ etcd_client_port }}"

    log "Running defragmentation only on local node: ${current_hostname} (${local_endpoint})"

    # Perform defragmentation on local endpoint only
    local failed=0
    if ! defrag_endpoint "${local_endpoint}"; then
        ((failed++))
    fi

    # Optional: Compact the keyspace after successful defragmentation
    if [ ${failed} -eq 0 ]; then
        log "Attempting keyspace compaction"
        local current_rev=$(timeout 10s /usr/local/bin/etcdctl \
            --endpoints="${local_endpoint}" \
            --cacert="${ETCD_CACERT}" \
            --cert="${ETCD_CERT}" \
            --key="${ETCD_KEY}" \
            endpoint status --write-out=simple | awk '{print $4}' | head -1 || echo "")

        if [ -n "${current_rev}" ] && [ "${current_rev}" != "0" ]; then
            if timeout 30s /usr/local/bin/etcdctl \
                --endpoints="${local_endpoint}" \
                --cacert="${ETCD_CACERT}" \
                --cert="${ETCD_CERT}" \
                --key="${ETCD_KEY}" \
                compact "${current_rev}"; then
                log "Successfully compacted keyspace to revision ${current_rev}"
            else
                log "WARNING: Failed to compact keyspace"
            fi
        else
            log "WARNING: Could not determine current revision for compaction"
        fi
    fi

    if [ ${failed} -eq 0 ]; then
        log "Defragmentation completed successfully"
        exit 0
    else
        log "Defragmentation completed with ${failed} failures"
        exit 1
    fi
}
main "$@"

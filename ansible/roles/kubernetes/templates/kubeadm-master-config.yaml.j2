apiVersion: kubeadm.k8s.io/v1beta3
kind: InitConfiguration
localAPIEndpoint:
  advertiseAddress: {{ ansible_host }}
  bindPort: 6443
nodeRegistration:
  criSocket: unix:///run/containerd/containerd.sock
  kubeletExtraArgs:
    node-ip: {{ ansible_host }}

---
apiVersion: kubeadm.k8s.io/v1beta3
kind: ClusterConfiguration
kubernetesVersion: {{ k8s_version | default('1.31') }}.0
clusterName: {{ kubernetes_cluster_name }}
controlPlaneEndpoint: {{ kubernetes_control_plane_endpoint }}

# External etcd cluster
etcd:
  external:
    endpoints:
{% for host in groups['etcds'] %}
      - https://{{ hostvars[host]['ansible_host'] }}:2379
{% endfor %}
    caFile: /etc/kubernetes/pki/etcd/ca.crt
    certFile: /etc/kubernetes/pki/apiserver-etcd-client.crt
    keyFile: /etc/kubernetes/pki/apiserver-etcd-client.key

# Networking
networking:
  serviceSubnet: {{ kubernetes_service_subnet }}
  podSubnet: {{ kubernetes_pod_subnet }}
  dnsDomain: cluster.local

# API Server configuration
apiServer:
  bindPort: 6443
  certSANs:
{% for host in groups['loadbalancers'] %}
    - {{ hostvars[host]['ansible_host'] }}
{% endfor %}
{% for host in groups['masters'] %}
    - {{ hostvars[host]['ansible_host'] }}
    - {{ hostvars[host]['ansible_hostname'] }}
{% endfor %}
    - 127.0.0.1
    - localhost
    - kubernetes
    - kubernetes.default
    - kubernetes.default.svc
    - kubernetes.default.svc.cluster.local
  extraArgs:
    audit-log-maxage: "{{ kubernetes_api_server_config.audit_log_maxage }}"
    audit-log-maxbackup: "{{ kubernetes_api_server_config.audit_log_maxbackup }}"
    audit-log-maxsize: "{{ kubernetes_api_server_config.audit_log_maxsize }}"
    enable-admission-plugins: "{{ kubernetes_api_server_config.enable_admission_plugins | join(',') }}"
    profiling: "false"

    service-node-port-range: 30000-32767

# Controller Manager configuration
controllerManager:
  extraArgs:
    bind-address: 0.0.0.0
    profiling: "false"
    terminated-pod-gc-threshold: "50"

# Scheduler configuration
scheduler:
  extraArgs:
    bind-address: 0.0.0.0
    profiling: "false"

---
apiVersion: kubeadm.k8s.io/v1beta3
kind: JoinConfiguration
nodeRegistration:
  criSocket: unix:///run/containerd/containerd.sock
  kubeletExtraArgs:
    node-ip: {{ ansible_host }}
controlPlane:
  localAPIEndpoint:
    advertiseAddress: {{ ansible_host }}
    bindPort: 6443

---
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
serverTLSBootstrap: {{ kubernetes_kubelet_config.server_tls_bootstrap | default(true) | lower }}
rotateCertificates: {{ kubernetes_kubelet_config.rotate_certificates | default(true) | lower }}
cgroupDriver: {{ kubernetes_kubelet_config.cgroup_driver }}
containerRuntimeEndpoint: {{ kubernetes_kubelet_config.container_runtime_endpoint }}
failSwapOn: {{ kubernetes_kubelet_config.fail_swap_on | default(false) | lower }}
clusterDomain: cluster.local
clusterDNS:
  - 10.96.0.10
authentication:
  anonymous:
    enabled: false
  webhook:
    enabled: true
    cacheTTL: 2m0s
  x509:
    clientCAFile: /etc/kubernetes/pki/ca.crt
authorization:
  mode: Webhook
  webhook:
    cacheAuthorizedTTL: 5m0s
    cacheUnauthorizedTTL: 30s

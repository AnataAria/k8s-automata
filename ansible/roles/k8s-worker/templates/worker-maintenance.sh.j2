#!/bin/bash
set -euo pipefail

LOG_FILE="/var/log/worker-maintenance.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

log "Starting worker node maintenance..."

log "Cleaning up exited containers..."
crictl ps -a --state exited -q | head -50 | xargs -r crictl rm 2>/dev/null || true

log "Cleaning up unused images..."
crictl rmi --prune 2>/dev/null || true

{% if maintenance.log_cleanup_enabled | default(true) %}
log "Cleaning up old log files..."
find /var/log -name "*.log" -type f -mtime +{{ maintenance.log_retention_days | default(30) }} -delete 2>/dev/null || true
find /var/log -name "*.gz" -type f -mtime +{{ maintenance.log_retention_days | default(30) }} -delete 2>/dev/null || true
{% endif %}

log "Cleaning up tmp files older than 7 days..."
find /tmp -type f -mtime +7 -delete 2>/dev/null || true

log "Checking disk usage..."
DISK_USAGE=$(df / | tail -1 | awk '{print $5}' | tr -d '%')
if [ "$DISK_USAGE" -gt 85 ]; then
    log "WARNING: Disk usage is ${DISK_USAGE}%"
fi

log "Worker node maintenance completed."

#!/bin/bash
set -euo pipefail

EXIT_CODE=0

check_kubelet() {
    if systemctl is-active --quiet kubelet; then
        echo "[OK] kubelet is running"
    else
        echo "[FAIL] kubelet is not running"
        EXIT_CODE=1
    fi
}

check_containerd() {
    if systemctl is-active --quiet containerd; then
        echo "[OK] containerd is running"
    else
        echo "[FAIL] containerd is not running"
        EXIT_CODE=1
    fi
}

check_kubelet_healthz() {
    if curl -sf http://127.0.0.1:{{ health_check.kubelet_healthz_port }}/healthz >/dev/null 2>&1; then
        echo "[OK] kubelet healthz endpoint is responding"
    else
        echo "[FAIL] kubelet healthz endpoint is not responding"
        EXIT_CODE=1
    fi
}

check_disk_space() {
    local disk_usage
    disk_usage=$(df / | tail -1 | awk '{print $5}' | tr -d '%')
    if [ "$disk_usage" -lt 85 ]; then
        echo "[OK] Disk usage: ${disk_usage}%"
    else
        echo "[WARN] Disk usage: ${disk_usage}% (threshold: 85%)"
        EXIT_CODE=1
    fi
}

check_memory() {
    local mem_available
    mem_available=$(awk '/MemAvailable/ {print int($2/1024)}' /proc/meminfo)
    if [ "$mem_available" -gt 200 ]; then
        echo "[OK] Available memory: ${mem_available}MB"
    else
        echo "[WARN] Low memory: ${mem_available}MB available"
        EXIT_CODE=1
    fi
}

echo "=== Worker Node Health Check ==="
echo "Hostname: $(hostname)"
echo "Date: $(date)"
echo "================================"

check_kubelet
check_containerd
check_kubelet_healthz
check_disk_space
check_memory

echo "================================"
if [ $EXIT_CODE -eq 0 ]; then
    echo "Overall: HEALTHY"
else
    echo "Overall: UNHEALTHY"
fi

exit $EXIT_CODE

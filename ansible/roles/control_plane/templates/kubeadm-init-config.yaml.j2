apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
clusterName: kubernetes
kubernetesVersion: "{{ k8s_version }}"
controlPlaneEndpoint: "{{ control_plane_endpoint }}"
networking:
  podSubnet: "{{ pod_network_cidr }}"
  serviceSubnet: "{{ service_cidr }}"
  dnsDomain: "{{ cluster_dns_domain }}"
etcd:
  external:
    endpoints:
{% for host in groups['etcd'] %}
      - "https://{{ hostvars[host].ip | default(hostvars[host].access_ip | default(hostvars[host].ansible_host)) }}:{{ control_plane_etcd_client_port }}"
{% endfor %}
    caFile: "/etc/kubernetes/pki/etcd/ca.crt"
    certFile: "/etc/kubernetes/pki/apiserver-etcd-client.crt"
    keyFile: "/etc/kubernetes/pki/apiserver-etcd-client.key"
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
localAPIEndpoint:
  advertiseAddress: "{{ control_plane_api_advertise_address }}"
  bindPort: 6443
nodeRegistration:
  criSocket: "{{ containerd_socket }}"
  kubeletExtraArgs:
    - name: node-ip
      value: "{{ control_plane_api_advertise_address }}"
